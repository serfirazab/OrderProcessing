<Project>
  <PropertyGroup>
    <!--
      NuGet Audit: fail the build on ANY known package vulnerability.
      This is the best practice — never suppress NU190x globally.
      If a vulnerability appears, fix it by updating the package or
      adding a transitive dependency version override in the relevant .csproj.
    -->
    <NuGetAudit>true</NuGetAudit>
    <NuGetAuditMode>all</NuGetAuditMode>
    <WarningsAsErrors>$(WarningsAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsAsErrors>
  </PropertyGroup>
</Project>
