@page "/orders/new"
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>New Order</PageTitle>

<h1>Create New Order</h1>

<div class="card p-4">
    <div class="mb-3">
        <label class="form-label">Customer Name</label>
        <input @bind="customerName" class="form-control" placeholder="John Doe" />
    </div>
    <div class="mb-3">
        <label class="form-label">Customer Email</label>
        <input @bind="customerEmail" type="email" class="form-control" placeholder="john@example.com" />
    </div>

    <h4 class="mt-3">Order Items</h4>

    @foreach (var item in items.Select((value, index) => new { value, index }))
    {
        <div class="card p-3 mb-2 bg-light">
            <div class="row g-2">
                <div class="col-md-4">
                    <input @bind="item.value.ProductName" class="form-control" placeholder="Product name" />
                </div>
                <div class="col-md-2">
                    <input @bind="item.value.UnitPrice" type="number" step="0.01" class="form-control" placeholder="Price" />
                </div>
                <div class="col-md-2">
                    <input @bind="item.value.Quantity" type="number" min="1" class="form-control" placeholder="Qty" />
                </div>
                <div class="col-md-2 d-flex align-items-center">
                    <span class="fw-bold">@((item.value.UnitPrice * item.value.Quantity).ToString("C"))</span>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-danger btn-sm" @onclick="() => RemoveItem(item.index)">Remove</button>
                </div>
            </div>
        </div>
    }

    <div class="mb-3">
        <button class="btn btn-outline-primary" @onclick="AddItem">+ Add Item</button>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <h4>Total: @items.Sum(i => i.UnitPrice * i.Quantity).ToString("C")</h4>
        <div>
            <button class="btn btn-secondary me-2" @onclick="GoBack">Cancel</button>
            <button class="btn btn-primary" @onclick="SubmitOrder" disabled="@isSubmitting">
                @(isSubmitting ? "Submitting..." : "Create Order")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger mt-3">@error</div>
    }
</div>

@code {
    private string customerName = "";
    private string customerEmail = "";
    private List<CreateOrderItemRequest> items = [new() { ProductName = "", UnitPrice = 10, Quantity = 1 }];
    private bool isSubmitting;
    private string? error;

    private void AddItem()
    {
        items.Add(new CreateOrderItemRequest { ProductName = "", UnitPrice = 10, Quantity = 1 });
    }

    private void GoBack() => Navigation.NavigateTo("/orders");

    private void RemoveItem(int index)
    {
        if (items.Count > 1)
            items.RemoveAt(index);
    }

    private async Task SubmitOrder()
    {
        error = null;
        isSubmitting = true;

        try
        {
            var request = new CreateOrderRequest
            {
                CustomerId = Guid.NewGuid(),
                CustomerName = customerName,
                CustomerEmail = customerEmail,
                Items = items.Where(i => !string.IsNullOrWhiteSpace(i.ProductName)).ToList()
            };

            var response = await Http.PostAsJsonAsync("/api/orders", request);
            response.EnsureSuccessStatusCode();

            Navigation.NavigateTo("/orders");
        }
        catch (Exception ex)
        {
            error = $"Failed to create order: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
