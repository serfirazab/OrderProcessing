@page "/orders"
@using Microsoft.EntityFrameworkCore
@inject OrderDbContext DbContext
@implements IDisposable

<PageTitle>Orders</PageTitle>

<h1>Orders Dashboard</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <button class="btn btn-primary" @onclick="RefreshOrders">
            🔄 Refresh
        </button>
        <span class="ms-2 text-muted small">Auto-refreshing every 3s</span>
    </div>
    <a href="/orders/new" class="btn btn-success">+ New Order</a>
</div>

@if (orders is null)
{
    <div class="alert alert-info">Loading orders...</div>
}
else if (orders.Count == 0)
{
    <div class="alert alert-warning">No orders yet. Create your first order!</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Total</th>
                <th>Status</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in orders)
            {
                <tr>
                    <td><code>@order.Id.ToString("N")[..8]...</code></td>
                    <td>@order.CustomerName</td>
                    <td>@order.Items.Count</td>
                    <td>@order.TotalPrice.ToString("C")</td>
                    <td>
                        <span class="badge @GetStatusBadge(order.Status)">
                            @order.Status
                        </span>
                    </td>
                    <td>@order.CreatedAt.ToLocalTime().ToString("g")</td>
                    <td>
                        <a href="/orders/@order.Id" class="btn btn-sm btn-outline-info">Detail</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Order> orders = [];
    private Timer? timer;

    protected override void OnInitialized()
    {
        timer = new Timer(async _ =>
        {
            await RefreshOrders();
            await InvokeAsync(StateHasChanged);
        }, null, 0, 3000);
    }

    private async Task RefreshOrders()
    {
        orders = await DbContext.Orders
            .Include(o => o.Items)
            .OrderByDescending(o => o.CreatedAt)
            .ToListAsync();
    }

    private string GetStatusBadge(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "bg-warning text-dark",
        OrderStatus.Processing => "bg-info text-dark",
        OrderStatus.Processed => "bg-success",
        OrderStatus.Failed => "bg-danger",
        _ => "bg-secondary"
    };

    public void Dispose()
    {
        timer?.Dispose();
    }
}
